<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/completedWorkoutDetailFragment"
        android:name="com.apppillar.feature_home.presentation.detail.CompletedWorkoutDetailFragment"
        android:label="CompletedWorkoutDetailFragment">
        <argument
            android:name="workoutId"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.apppillar.feature_home.presentation.HomeFragment"
        android:label="HomeFragment">
        <action
            android:id="@+id/action_homeFragment_to_completedWorkoutDetailFragment"
            app:destination="@id/completedWorkoutDetailFragment" />
        <deepLink
            android:id="@+id/deepLink"
            app:uri="amfit://home" />
    </fragment>
    <fragment
        android:id="@+id/userProfileFragment"
        android:name="com.apppillar.feature_home.presentation.UserProfileFragment"
        android:label="UserProfileFragment">
        <action
            android:id="@+id/action_userProfileFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <deepLink
            android:id="@+id/deepLink2"
            app:uri="amfit://userProfile" />
    </fragment>
</navigation>